{
  "manifest_version": 3,
  "name": "IELTSy Writer",
  "version": "0.3.0",
  "description": "Grammar checking and A1–B2 → C1–C2 vocabulary upgrades for IELTS writing.",
  "browser_specific_settings": {
    "gecko": {
      "id": "ieltsy-writer@example.com",
      "strict_min_version": "115.0"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api.languagetool.org/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["words.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "IELTSy Writer"
  }
}
